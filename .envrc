# rdog daemon 的环境变量示例。
# 注意:
# - 这里默认只保留“注释示例”,避免进入目录时悄悄覆盖 TOML 配置
# - 如果你确实需要临时覆盖某个配置,按需取消注释对应项

# export RDOG_DAEMON__RETRY_SECONDS=5
# export RDOG_OUTBOUND__ENABLED=false
# export RDOG_INBOUND__ENABLED=true

# 按需取消注释,覆盖主动连出端点。
# export RDOG_OUTBOUND__HOST=127.0.0.1
# export RDOG_OUTBOUND__PORT=4444
# export RDOG_OUTBOUND__SHELL=/bin/bash
# export RDOG_OUTBOUND__MODE=interactive
# 说明:
# - interactive: 默认 shell 暴露模式
# - control: 显式 `@...` 控制协议接收模式

# 按需取消注释,覆盖被动监听端点。
# export RDOG_INBOUND__HOST=0.0.0.0
# export RDOG_INBOUND__PORT=5555
# export RDOG_INBOUND__SHELL=/bin/bash
# export RDOG_INBOUND__MODE=control

# 按需取消注释,开启真实 macOS AX E2E。
# 这会打开真实 Terminal 测试窗口,并要求实际运行 rdog daemon/control 的进程拥有 Accessibility 权限。
# export RDOG_LIVE_AX_E2E=1
# 如果已授权的是安装版 rdog,可以把 live 测试指向那份二进制。
# export RDOG_LIVE_AX_E2E_BINARY=/Users/cuiluming/.cargo/bin/rdog
# 如果 Accessibility 权限给的是 Terminal.app 宿主,让测试通过 Terminal 启动临时 daemon。
# export RDOG_LIVE_AX_E2E_VIA_TERMINAL=1

# 按需取消注释,启用 Zenoh peer/peer LAN profile。
# export RDOG_ZENOH__ENABLED=true
# export RDOG_ZENOH__NAMESPACE=lab
# export RDOG_ZENOH__DAEMON_NAME=mini-a.lab
# export RDOG_ZENOH__REQUEST_TIMEOUT_MS=3000
# export RDOG_ZENOH__STARTUP_GUARD_WINDOW_MS=1000
if [ -f ".envrc.private" ]; then
  source_env ".envrc.private"
fi
